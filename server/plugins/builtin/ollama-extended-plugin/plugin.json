    {
      "id": "defaultModel",
      "type": "string",
      "label": "Standard-Modell",
      "description": "Standard-Modell für Ollama-Anfragen",
      "default": "llama3"
    },
    {
      "id": "contextWindow",
      "type": "number",
      "label": "Kontext-Fenster",
