{
  "name": "opencognit",
  "private": false,
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node --env-file=.env node_modules/.bin/tsx server/index.ts",
    "dev": "concurrently -n server,ui -c blue,green \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "node --env-file=.env node_modules/.bin/tsx watch server/index.ts",
    "dev:ui": "node --env-file=.env ./node_modules/.bin/vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:seed": "tsx server/db/seed.ts",
    "db:migrate": "tsx server/db/migrate-cli.ts",
    "db:keygen": "node -e \"console.log('ENCRYPTION_KEY=' + require('crypto').randomBytes(32).toString('hex'))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.96.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "discord.js": "^14.26.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "imap": "^0.8.19",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.574.0",
    "mailparser": "^3.9.8",
    "motion": "^12.0.0",
    "nodemailer": "^8.0.6",
    "ogl": "^1.0.11",
    "playwright": "^1.59.1",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "tailwind-merge": "^3.5.0",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.18",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
